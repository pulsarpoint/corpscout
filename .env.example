# corpscout/.env.example
# Copy to .env and fill in values

# Scheduler
DATABASE_URL=postgres://corpscout:corpscout@localhost:5435/corpscout?sslmode=disable
CORPSCOUT_LISTEN_ADDR=:8090
CORPSCOUT_CRAWLER_URL=http://localhost:8000
CORPSCOUT_CRAWL_CONCURRENCY=5
CORPSCOUT_DOMAIN_CONCURRENCY=10

# Crawler
CRAWLER_LISTEN_ADDR=:8000
CRAWLER_OPENAI_API_KEY=         # Required only for Crawl4AI adapters (sources without a structured API)
CRAWLER_LLM_MODEL=gpt-4o-mini
CRAWLER_CERTSH_RATE_LIMIT=2
CRAWLER_OPENCORPORATES_API_KEY= # Optional; enables higher rate limits on OpenCorporates
